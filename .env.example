# ─── LLM classifier (optional) ────────────────────────────────────────────
# The /api/scan/llm endpoint adds an LLM "second opinion" on top of the
# regex engine. It is provider-agnostic: any OpenAI Chat Completions
# compatible endpoint works. If unset, prompt-guard runs regex-only.

# Base URL of an OpenAI-compatible API. Examples:
#   OpenAI      https://api.openai.com/v1   (default)
#   OpenRouter  https://openrouter.ai/api/v1
#   Groq        https://api.groq.com/openai/v1
#   Together    https://api.together.xyz/v1
#   Ollama      http://localhost:11434/v1     (local, open-source, no key)
#   LM Studio   http://localhost:1234/v1      (local, open-source, no key)
#   llama.cpp   http://localhost:8080/v1      (local, open-source, no key)
PROMPT_GUARD_LLM_BASE_URL=https://api.openai.com/v1

# API key for the endpoint above. NOT required for local engines (localhost).
PROMPT_GUARD_LLM_API_KEY=

# Model name as understood by the endpoint.
#   OpenAI: gpt-4o-mini   OpenRouter: meta-llama/llama-3.1-8b-instruct
#   Ollama: llama3.1      Groq: llama-3.1-8b-instant
PROMPT_GUARD_LLM_MODEL=gpt-4o-mini

# Request strict JSON output (response_format). Some local engines reject it.
# Leave unset/false for max compatibility; parsing handles plain text anyway.
PROMPT_GUARD_LLM_JSON_MODE=false
